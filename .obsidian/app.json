{
  "vimMode": true,
  "useTab": false,
  "spellcheck": true,
  "strictLineBreaks": true,
  "foldHeading": true,
  "foldIndent": true,
  "showLineNumber": true,
  "showUnsupportedFiles": true,
  "attachmentFolderPath": "p/media",
  "legacyEditor": false,
  "spellcheckLanguages": [
    "es-419",
    "en-US"
  ],
  "alwaysUpdateLinks": true,
  "communityPluginSortOrder": "release",
  "pdfExportSettings": {
    "pageSize": "Letter",
    "landscape": false,
    "margin": "0",
    "downscalePercent": 100
  },
  "livePreview": false,
  "fileSortOrder": "alphabetical",
  "showInlineTitle": true
}