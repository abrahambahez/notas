@book{castilloberthier1984,
  title = {Basurero Antropolog\'ia de La Miseria},
  author = {Castillo Berthier, Hector},
  year = {1984},
  publisher = {{Edamex}},
  isbn = {968-409-256-3},
  note = {Resumen
\par
Este libro es una etnograf\'ia sobre los basureros de la ciudad de M\'exico, a partir de siete ~*\guillemotleft historias de la vida\guillemotright * de los trabajadores de la basura en la ciudad de M\'exico.
\par
Primer encuentro. Un mal primer acercamiento, es necesario trabajar de *\guillemotleft machetero\guillemotright * (voluntario sin sueldo para separar la basura) al menos tres semanas para hacer amistad con *el Prieto*, otro machetero del cami\'on y futuro informante en el tiradero de Santa Cruz
\par
Pepe \guillemotleft el mugres\guillemotright{} lleg\'o de Hidalgo y es barrendero, alcoh\'olico y tiene dos familias. La interpretaci\'on de Castillo Berthier es que la juerga resulta cat\'artica para sobrellevar la dureza de la vida en que se reconocen (sobre todo las mujeres, que en el texto s\'olo son due\~nas de los locales u objeto sexual).
\par
Las fiestas patrias en Santa Cruz Meyehualco. Las descripciones sobre las casas (que se considerar\'ian [[infravivienda]]) y los paisjes donde se ecnuentran.
\par
El hijo de la revoluci\'on. *\guillemotleft Claro que s\'i tuve madre, aunque no la conoc\'i porque muri\'o cuando yo nac\'i, pero a mi pap\'a, a ese s\'i lo conoc\'i. Pele\'o en la revoluci\'on con los villistas, con los zapatistas, con los federales y con todos los grupos que surg\'ia, porque en ese momento hab\'ia que andar nom\'as a la 'cargada' si quer\'ia uno seguir viviendo\guillemotright * [@castilloberthier1984, p. 71]. Usos pol\'iticos de los barrenderos y pepenadores, desde porra y votante hasta grupos de choque y halcones.
\par
El juego del \guillemotleft limpias\guillemotright. Un partido de futbol desencadena un espect\'aculo expresivo de versos y albures.
\par
La fiesta de la virgen. *\guillemotleft La tierra es de quien la trabaja. La basura es de los pepenadores que la trabajan\guillemotright * [p. 116]
\par
Adi\'os al \guillemotleft Mu\'egano\guillemotright. Las vidas breves, mutiladas, de los pepenadores.}
}

@article{castilloberthier1990,
  title = {La Sociedad de La Basura},
  author = {Castillo Berthier, H{\'e}ctor},
  year = {1990},
  journal = {Ciencias},
  number = {020},
  note = {Castillo pinta un paisaje inicial intenso de los basureros a cielo abierto para introducir a los sujetos de su estudio: las personas que viven de la basura.
\par
Los estudios sobre la problem\'atica de la basura comienza a principios de los setenta [@castilloberthier1990, p. 26]
\par
El proceso de desecho comienza sacando la basura: con el proceso de meter el objeto en una bolsa y sacarlo de su casa.
\par
Circuito de la basura en el DF de los noventa:
\par
Muchos recolectores, barrenderos en el DF, reciben gratificaciones por recibir la basura y cuando van a depositarla, los receptores pedir\'an una parte de las gratificaciones, motivando la repetici\'on del ciclo. El chofer y un par m\'as de personas reciben un salario, pero hay otras personas que los acompa\~nan a manera de *voluntarios*, cuyo ingreso depende de la separaci\'on de los desechos para su reventa en lugares que compran "desechos industriales" [@castilloberthier1990, p. 28]
\par
Las \guillemotleft fincas\guillemotright{} y el acto de *\guillemotleft finquear\guillemotright * consiste en recorrer negocios y comercios que hay en la ruta para recoger la basura a cambio de una cuota preestablecida.
\par
Al final del d\'ia se recibe dinero de los barrenderos, de las \guillemotleft fincas\guillemotright, que se vendieron los materiales previamente separados y que se repartieron las ganancias, el cami\'on se dirige una de las diez *estaciones de transferencia*, donde los choferes de cami\'on pagan una cuota a los choferes del trailer de transferencia (m\'as grande) para poder descargar. En la estaci\'on la basura vuelve a separarse a cargo de los empleados de la misma. Finalmente, el trailer lleno tirar\'a la basura restante en el tiradero a cielo abierto asignado.}
}

