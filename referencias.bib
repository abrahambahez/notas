@article{masis2009,
  title = {{De la vida hist\'orica: Auge y apor\'ias del historicismo decimon\'onico}},
  author = {Mas{\'i}s, Jethro},
  year = {2009},
  month = oct,
  journal = {Konvergencias: Filosof\'ia y Culturas en Di\'alogo},
  volume = {Vii},
  number = {21},
  pages = {208--250.},
  abstract = {This study deals with the philosophical problems of historical conscience which arose in conjunction with the wake of 19th century Historicism, whose aim was to do away with the metaphysical presuppositions of German Idealism. The heyday of the historicist movement shall be dealt with as well as its vacillating contradictions (its metaphysics).},
  langid = {spanish},
  keywords = {s2},
  note = {\#\# El acontecimiento de la conciencia hist\'orica
\par
- Estar situado hist\'oricamente, reconocer la finitud y 
\par
- Tiempo hist\'orico vs eternidad
\par
\#\# El historicismo
\par
- Es una nueva sensibilidad hist\'orica que se refleja en una actitud investigativa claramente antihegeliana (p. 210)
\par
- Seg\'un Mandelbaum: se puede comprender cualquier **fen\'omeno** consider\'andolo en t\'erminos del lugar y el papel que ha tenido en un **\textbackslash [como\textbackslash ] proceso de desarrollo**
\par
- El descubrimiento de que el pasado es fundamentalmente diferente del presente (conciencia hist\'orica)
\par
- En su relaci\'on con el inter\'es de hundir al idealismo hegeliano
\par
- La singularidad y la contingencia de los sucesos hist\'oricos vs la totlizaci\'on idealista de una filosof\'ia de la Historia
\par
- historia vs naturaleza: como son fundamentalmente diferentes, no deber\'ian estudiarse de la misma manera
\par
- *La particularidad prima sobre la generalidad*.
\par
- Naturalismo vs historicismo: choque de dos perspectivas totalizantes basadas en el estudio de dos objetos disntintos: lo natural / lo hist\'orico
\par
- Leopold von Ranke: fundador de la 'historia cient\'ifica':
\par
- Deshacerse del yo para obtener el fen\'omeno hist\'orico
\par
- M\'etodo filol\'ogico: el documento es el que habla
\par
- Toda historia es universal en tanto que debe considerar la interrelacionalidad en que las cosas particulares se vinculan
\par
- El historiador no es un mero recolector de datos, sino que su arte est\'a en la reconstrucci\'on de lo invisible
\par
\#\#\# Dilthey
\par
- Se hacerca a Kant, el sujeto como determinante de toda objetividad
\par
- A las ciencias naturales les es esencial olvidar su propia historia
\par
- Kant identifica al conocimiento con la forma l\'ogica
\par
- Una nueva l\'ogica de la historia, \textquestiondown cu\'al?
\par
- Dilthey reconoce la determinabilidad hist\'orica de lo humano, incalculabilidad de lo hist\'orico en cuanto *vida* y su nunca resoluci\'on teor\'etica en la idea o en lo que fuere que suponga una racionalizaci\'on cabal, pero tampoco es un positivista decidido
\par
\#\#\# Historicismo y teolog\'ia liberal
\par
- Teolog\'ia liberal rechaza los dogmas y tradiciones eclasiales, la realizaci\'on del esp\'iritu cristiano en la libertad intelectual
\par
- Schleiermacher la religi\'on como *intuici\'on del universo*
\par
- Nietzche (no por te\'ologo, por supuesto): Los historiadores yerran desde el principio porque su interpuso la ciencia para exigir que la historia deba ser ciencia (p. 246)
\par
Al no cuestionar la mirada, el historicismo carece de radicalidad (p. 247)}
}

@book{mathews2017,
