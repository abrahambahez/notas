  year = {2021},
  journal = {Antr\'opica. Revista de Ciencias Sociales y Humanidades},
  volume = {7},
  number = {14},
  pages = {373--402},
  abstract = {El texto es un esfuerzo que estimula debatir, transici\'on democr\'atica de por medio, el papel del Estado transnacional en la pen\'insula de Yucat\'an mediante un encadenado y err\'atico arribo de decenas de megaproyectos capitalistas a partir de la d\'ecada de 1990. El an\'alisis busca entender la influencia de esos factores en el ocaso, si no debacle, del territorio ancestral conformado entre 1240 y 1540 agudizada por la pandemia del covid-19. Finalmente, se incluye una exposici\'on breve pero cr\'itica de las acciones y movimientos de resistencia en favor de su preservaci\'on. Una lista de pueblos y organizaciones que impulsan la lucha por la recuperaci\'on f\'isica y simb\'olica del territorio se ofrece en el Anexo I, como apunte obligado frente a la mirada del agresivo contexto e intereses globales que apuntan a exterminarlo},
