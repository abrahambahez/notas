@article{ardillayrueda2013,
  title = {La Saturaci\'on Te\'orica En La Teor\'ia Fundamentada: {{Su}} de-{{Limitaci\'on}} En El An\'alisis de Trayectorias de Vida de V\'ictimas Del Desplazamiento Forzado En {{Colombia}}},
