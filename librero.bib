@article{pascual2014,
  title = {{El giro espacial en historia. Derivas conceptuales y racconto historiogr\'afico en Argentina. Imaginar los espacios de segregaci\'on localizados The spatial turn in history. Conceptual drifts and argentina\textasciiacute s historiographical racconto. Imagining located...}},
  author = {Pascual, Cecilia Mar{\'i}a},
