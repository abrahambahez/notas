@book{ingold2011a,
  title = {The Perception of the Environment: {{Essays}} on Livelihood, Dwelling and Skill},
  shorttitle = {The Perception of the Environment},
  author = {Ingold, Tim},
  year = {2011},
  publisher = {{Routledge}},
  isbn = {978-0-203-46602-5},
  langid = {english},
  keywords = {s2,tecnología},
  note = {\#\# Herramientas, mentes y m\'aquinas 
\par
\textquestiondown Las m\'aquinas hacen historia (son agentes sujetos a procesos marcados temporalmente)? es la pregunta que Heilbroner usa como t\'itulo en su art\'iculo de 1967 donde identifica el problema del determinismo tecnol\'ogico (p. 295). 
\par
\textquestiondown Cu\'al es la diferencia entre el uso de la herramienta y el desempe\~no de la m\'aquina? 
\par
La tecnolog\'ia est\'a tan presente en nuestra \'epoca que asumimos que donde hay herramientas siendo usadas *debe existir* una tecnolog\'ia, aunque debemos observar las implicaciones de esta afirmaci\'on. 
\par
Etimol\'ogicamente, la tecnolog\'ia est\'a relacionada a la habilidad humana (*gr. techn\'e; lat. ars*, ver figura 15.1 al inicio de la p. 296). El cambio de esa concepci\'on a la actual *tecnolog\'ia* tiene que ver con un cambio en la cosmovisi\'on que entendi\'o un *universo mec\'anico*. 
\par
El *artesano* tiene un conocimiento profundo de la obra. Aunque sus m\'etodos podr\'ian ser poco claros, la parte operativa implica reglas procedimentales formales y expl\'icitas, que constituyen el *logos* en la *tekhn\'e*. As\'i se establece la distinci\'on entre el dise\~no y la construcci\'on de las cosas. La cosa es virtualmente concebida antes que su realizaci\'on pr\'actica. actualmente estas fases se identifican con la ingenier\'ia y la tecnolog\'ia, respectivamente. La tecnolog\'ia queda reducida a *lo mec\'anico* (*m\'ekhan\'e*, p. 295). 
\par
Lo mec\'anico tiene una separaci\'on entre el trabajo constructivo y el contexto de la experiencia sensorial; all\'a donde los movimientos de un aparato instrumental ejecutan un dise\~no dado y est\'an prescritos desde sus condiciones iniciales para seguir una ruta fija, est\'a *lo mec\'anico*. Las prescripciones encarnadas en la m\'aquina, derivadas de la aplicaci\'on de leyes cient\'ificas, son tecnol\'ogicas. 
\par
Construcci\'on, vivienda habitar 
\par
El texto aborda c\'omo los animales y las personas *se hacen* en su habitat dentro del mundo. Especialmente pensando en el sentido de lo arquitect\'onico, es decir, la parte del entorno que convencionalmente se describe como \guillemotleft construida\guillemotright{} (p. 172). 
\par
En la persepctiva de la construcci\'on subyace la idea de que *el entorno es aquello que puede ser tomado, y por extensi\'on, apropiado*. La necesidad de explicar el origen de las primeras casas tiene inter\'es arquitect\'onico y arqueol\'ogico, pero tambi\'en tiene como fundamento a la perspectiva de la construcci\'on: los primeros constructores ejecutaron un plan que resolv\'ia un problema, el refugio, ya pensado dentro de su imaginaci\'on (p. 184) 
\par
Oclc: 950744937}
}

@book{ingold2013,
  title = {Making: {{Anthropology}}, Archaeology, Art and Architecture},
  shorttitle = {Making},
  author = {Ingold, Tim},
  year = {2013},
  publisher = {{Routledge}},
  address = {{London ; New York}},
  isbn = {978-0-415-56722-0 978-0-415-56723-7},
  keywords = {Architecture and anthropology,Art and anthropology,Ethnoarchaeology,Ethnology,Methodology,Philosophy,Social archaeology,SOCIAL SCIENCE / Anthropology / General},
  note = {\#\# Aprender a aprender 
\par
Aprender *con*, no aprender *sobre* lo que estudiamos es la propuesta. \guillemotleft La \'unica manera en que uno puede ralmente saber cosas -esto es, desde lo profundo de nuestro ser- es a trav\'es de un proceso de autodescubrimiento\guillemotright{} (p. 1). El conocimiento como un proceso activo de experimentaci\'on que no se hace a trav\'es de la experiencia sino que *es* la experiencia. Una noci\'on af\'in es la de *deutero-learning* de Bateson: un aprendizaje que no nos da *hechos* sobre el mundo, sino que nos prepara para que \'el nos ense\~ne. 
\par
La antropolog\'ia cuestiona la proposici\'on epistemol\'ogica principal de legimitidad institucional de la escuela: que la academia nos da una visi\'on autorizada de c\'omo funciona el mundo, llev\'andose consigo los sofismas de la intuici\'on, la experiencia o el sentido com\'un. Al *aprender* de otro modo otros modos de vida y de conocimiento, la pretensi\'on de universalidad es cuestionada (p. 2). 
\par
\#\# El curso 
\par
El curso que Ingold pretende sobre las cuatro A es involucrar a los estudiantes en *el arte de la investigaci\'on*: afinar sus poderes de observaci\'on, estimularlos a pensar *a trav\'es de* la observaci\'on y no *despu\'es* de ella, aprender a aprender, seguir movimientos, responder a cambios con juicio y precisi\'on, incluso aprender a so\~nar (p. 11). 
\par
El objetivo de un estudiante no es aprender un amplio corpus de conocimiento proposicional autorizado por una fuente acadpemica superior, sino colaborar en la b\'usqueda compartida de la comprensi\'on humana. 
\par
\#\# Este libro 
\par
Si el objetivo \'ultimo de la antropolog\'ia no es documental sino transformacional, no ser\'ia apropiado entregar un futuro id\'entico a como lo hemos recibido del pasado. Ense\~nar es la otra cara de la observaci\'on participante (y no la escritura etnogr\'afica) y ambas (observaci\'on participante y ense\~nanza) son la clave de una antropolog\'ia como *arte de investigar*: *\guillemotleft To teach anthropology is to practise anthropology; to practise anthropology is to teach it\guillemotright * (p. 13).}
}

@article{ingold2017,
  title = {{\textexclamdown Suficiente con la etnograf\'ia!}},
  author = {Ingold, Tim},
  year = {2017},
  journal = {Revista Colombiana de Antropolog\'ia},
  issn = {0486-6525},
  langid = {spanish},
  note = {\section{Anotaciones\textbf{
(5/9/2022 12:36:50)}}

\textbf{ 
\par
"Arguyo que atribuir la etnograficidad a los encuentros con aquellos con quienes llevamos a cabo nuestra investigaci\^Un, o en general al trabajo de campo, socava tanto el compromiso ontol\^Ugico como el prop\^Usito educativo de la antropolog\`Ia como disciplina, as\`I como su forma principal de trabajo, a saber, la observaci\^Un participante." (Ingold, 2017, p. 143) 
\par
"Estoy seguro de que hablo por la mayor\`Ia de los colegas antrop\^Ulogos al desaprobar el abuso del t\`Ermino que se ha vuelto un lugar co\.m n en las ciencias sociales m{$\cdot$}s all{$\cdot$} de nuestras fronteras" (Ingold, 2017, p. 144) 
\par
"gualmente, tenemos derecho a protestar cuando aquellos que eva{\.l} an nuestras propias propuestas nos exigen a nosotros en nombre de la etnograf\`Ia la misma adhesi\^Un servil a los protocolos de la metodolog\`Ia positivista, al requerirnos especificar, por ejemplo, con cu{$\cdot$}ntas personas esperamos hablar, por cu{$\cdot$}nto tiempo y c\^Umo ser{$\cdot$}n seleccionadas" (Ingold, 2017, p. 145) 
\par
"parece que todo lo que el etn\^Ugrafo toca con su mano es, prima facie, etnogr{$\cdot$}fico" (Ingold, 2017, p. 145) 
\par
"Tal como de los pintores holandeses del siglo XVII, se puede decir que los etn\^Ugrafos europeos y norteamericanos del siglo XX practicaron un arte de describir (Alpers 1983), pero en vez de usar l\`Inea y color, lo hicieron predominantemente con las palabras. Este es todav\`Ia un est{$\cdot$}ndar contra el que medimos el trabajo contempor{$\cdot$}neo. Estos asuntos han sido debatidos hasta la saciedad, y mucho de este debate ha ca\`Ido bajo la \.r brica de la llamada crisis de representaci\^Un. Muy razonablemente se han hecho preguntas pol\`Emicas sobre qui\`En tiene el derecho de describir, con base en qu\`E una descripci\^Un puede considerarse como m{$\cdot$}s veraz o autorizada que cualquier otra, en qu\`E medida la presencia del autor puede o debe ser reconocida dentro del texto y c\^Umo todo el proceso de escribirla puede hacerse de manera m{$\cdot$}s colaborativa." (Ingold, 2017, p. 146) 
\par
(Ingold, 2017, p. 147) Etnograf\'ia es el resultado del proceso de encuentro, aprendizaje y desarrollo de competencias culturales 
\par
"la observaci\^Un participante no es en absoluto una t\`Ecnica encubierta de recolecci\^Un de informaci\^Un sobre las personas con el pretexto de aprender de ellas. Es m{$\cdot$}s bien una realizaci\^Un, de obra y de palabra, de lo que le debemos al mundo por nuestro desarrollo y formaci\^Un. Esto es lo que quiero decir cuando hablo de compromiso ontol\^Ugico." (Ingold, 2017, p. 150) 
\par
"Como m\`Inimo, la observaci\^Un participante consiste precisamente en tal pr{$\cdot$}ctica y hace un llamado al antrop\^Ulogo novato para que preste atenci\'on: prestar atenci\^Un a lo que otros hacen o dicen y a lo que est{$\cdot$} sucediendo a su alrededor; seguir a los otros adonde vayan y cumplir sus \^Urdenes, sin importar lo que esto implique y ad\^Unde lo pueda llevar. Esto puede ser desconcertante e implica un riesgo existencial considerable." (Ingold, 2017, p. 151) 
\par
"correspondencia" (Ingold, 2017, p. 152) 
\par
"se trata de responder a estos eventos con intervenciones, preguntas y respuestas propias o, en otras palabras, de vivir con otros y vivir con otros prestando atenci\'on." (Ingold, 2017, p. 152) 
\par
"Donde quiera que usted los encuentre, los humanos se est{$\cdot$}n humanando. Es decir, se est{$\cdot$}n correspondiendo como quienes escriben cartas, trazando sus pensamientos y sentimientos y en espera de respuestas, est{$\cdot$}n viviendo vidas que se tejen las unas alrededor de las otras a lo largo de sendas que se extienden cada vez m{$\cdot$}s." (Ingold, 2017, p. 152) 
\par
"practicar la observaci\^Un participante consiste en unirse en correspondencia con aquellos con quienes aprendemos o entre quienes estudiamos, en un movimiento que va hacia adelante en el tiempo en vez de hacia atr{$\cdot$}s. Aqu\`I yacen el prop\^Usito, la din{$\cdot$}mica y el potencial educativo de la antropolog\`Ia que, como tal, es todo lo contrario a la etnograf\`Ia, cuyos objetivos descriptivos o documentales imponen sus propias finalidades en estas trayectorias de aprendizaje, y las convierten en ejercicios de recolecci\^Un de datos destinados a producir resultados, generalmente, en la forma de art\`Iculos o monograf\`Ias de investigaci\^Un" (Ingold, 2017, p. 153) 
\par
"El etn\^Ugrafo escribe y el antrop\^Ulogo un observador corresponsal, en general elabora su forma de pensar en el mundo (Ingold 2011, 241-243)" (Ingold, 2017, p. 154) 
\par
"Sin embargo, yo retar\`Ia a aquellos que insisten en usar la palabra etnogr\'afico a describir el conocimiento que surge a partir de sus involucramientos colaborativos (o de correspondencia) con las personas con quienes trabajan, a que expliquen por qu\`E no consideran igual de adecuado describir de la misma manera el conocimiento que surge de su correspondencia con colegas y estudiantes. \o No ser{$\cdot$} porque, a pesar de todas las protestas en contra, siguen siendo c\^Umplices de reproducir una distinci\^Un perniciosa entre aquellos con quienes y de quienes aprendemos, dentro y fuera de la academia respectivamente?" (Ingold, 2017, p. 155) 
\par
"El conocimiento es conocimiento, donde quiera que se cultive, y como nuestro prop\^Usito de adquirirlo dentro de la" (Ingold, 2017, p. 155) 
\par
"academia es (o debe ser) educativo en vez de etnogr{$\cdot$}fico, tambi\`En deber\`Ia serlo m{$\cdot$}s all{$\cdot$} de la academia." (Ingold, 2017, p. 156) 
\par
"Ciertamente, la etnograf\`Ia y la teor\`Ia se parecen m{$\cdot$}s que nada a dos arcos de la hip\`Erbola, que lanzan sus rayos en direcciones opuestas, iluminando las superficies de la mente y el mundo respectivamente" (Ingold, 2017, p. 158)
\par
}}
}

