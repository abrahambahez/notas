  issn = {1988-8333, 0210-847x},
  doi = {10.3989/ceg.2003.v50.i116.126},
  abstract = {In this article we analyze the epistemologic bonds between the braudelian concept of longue dur\'ee and its particular interpretation of the history of civilizations. The work consists of three epigraphs: \guillemotleft Continuity and discontinuity of the civilizations\guillemotright; \guillemotleft Uniformity and diversity of civilizations\guillemotright{} (where we pay special attention to the reflections of Femand Braudel around the industrial civilization, the national civilizations or the Marxist civilization) and \guillemotleft The triple mechanism of the braudelian de\~nnition of civilization: the cultural area, the loan and the repulse\guillemotright. In the final balance the author of this article assures that the concept civilization hides itself one catoptric structure that makes the diffuse image of the historian always appear reflected and, in this sense, Braudel did not constitute an exception.},
