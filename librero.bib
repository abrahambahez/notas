  title = {{La casa maya contempor\'anea: Usos, costumbres y configuraci\'on espacial}},
  shorttitle = {{La casa maya contempor\'anea}},
  author = {S{\'a}nchez Su{\'a}rez, Aurelio},
  year = {2006},
  month = dec,
  journal = {Pen\'insula},
  volume = {1},
  number = {2},
  pages = {81--105},
  publisher = {{Universidad Nacional Aut\'onoma de M\'exico, Centro Peninsular en Humanidades y Ciencias Sociales}},
